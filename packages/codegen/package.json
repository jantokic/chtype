{
  "name": "@chtype/codegen",
  "version": "0.1.0",
  "description": "Generate TypeScript types from your ClickHouse schema",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "chtype": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.0",
    "citty": "^0.1.6",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "MIT",
  "keywords": ["clickhouse", "typescript", "codegen", "type-safe", "orm", "schema"]
}
