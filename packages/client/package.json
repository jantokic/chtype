{
  "name": "@chtype/client",
  "version": "0.1.0",
  "description": "Type-safe ClickHouse client wrapper powered by generated schema types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.0"
  },
  "peerDependencies": {
    "@chtype/query": "workspace:*"
  },
  "devDependencies": {
    "@chtype/query": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist"],
  "license": "MIT",
  "keywords": ["clickhouse", "typescript", "client", "type-safe"]
}
